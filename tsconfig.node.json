{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "vite.config.ts",
    "test/**/*.ts",
    "src/types/**/*.ts",
    "src/theme/**/*.ts",
    "src/utils/**/*.ts",
    "src/constants/monacoThemes.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": false,
    "noImplicitAny": false,
    "types": ["node", "vite-plus/client"]
  }
}
